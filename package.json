{
  "name": "common-platform",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:file": "nest start file-service",
    "start:file:dev": "nest start file-service --watch",
    "start:notification": "nest start notification-service",
    "start:notification:dev": "nest start notification-service --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod:file": "node dist/apps/file-service/main",
    "start:prod:notification": "node dist/apps/notification-service/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e:file": "jest --config ./apps/file-service/test/jest-e2e.json",
    "test:e2e:notification": "jest --config ./apps/notification-service/test/jest-e2e.json",
    "typeorm": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:file": "cross-env NODE_ENV=development pnpm typeorm -d libs/database/src/config/file-typeorm.config.ts",
    "typeorm:notification": "cross-env NODE_ENV=development pnpm typeorm -d libs/database/src/config/notification-typeorm.config.ts",
    "migration:generate:file": "pnpm typeorm:file migration:generate",
    "migration:generate:notification": "pnpm typeorm:notification migration:generate",
    "migration:create:file": "pnpm typeorm migration:create",
    "migration:create:notification": "pnpm typeorm migration:create",
    "migration:run:file": "pnpm typeorm:file migration:run",
    "migration:run:notification": "pnpm typeorm:notification migration:run",
    "migration:revert:file": "pnpm typeorm:file migration:revert",
    "migration:revert:notification": "pnpm typeorm:notification migration:revert",
    "migration:show:file": "pnpm typeorm:file migration:show",
    "migration:show:notification": "pnpm typeorm:notification migration:show"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "bullmq": "^5.77.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "dotenv-flow": "^4.1.0",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.9",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@types/winston": "^2.4.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}